# PostgreSQL
POSTGRES_DB=echoim
POSTGRES_USER=echoim
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Server
# 本地开发时使用 localhost；docker compose 会自动构建容器内的 DATABASE_URL，无需修改
DATABASE_URL=postgresql://echoim:changeme@localhost:5432/echoim
JWT_SECRET=change-me-to-a-long-random-string
PORT=3000
SERVER_PORT=3000

# Client (nginx 暴露端口)
CLIENT_PORT=80
