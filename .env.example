# PostgreSQL
POSTGRES_DB=echoim
POSTGRES_USER=echoim
POSTGRES_PASSWORD=changeme

# Server
# 本地开发时使用 localhost；docker compose 会自动构建容器内的 DATABASE_URL，无需修改
DATABASE_URL=postgresql://echoim:changeme@localhost:5432/echoim
JWT_SECRET=change-me-to-a-long-random-string
INVITE_CODES=code1,code2
# 可选：上传文件根目录。不设置时默认使用当前工作目录下的 uploads/
# 例如测试环境可单独设为 /absolute/path/to/server/test-uploads，避免和开发环境互相清理
# UPLOADS_DIR=/absolute/path/to/uploads
PORT=3000

# Redis
REDIS_URL=redis://localhost:6379
